#!/bin/bash
# hex-doctor — Unified health check entry point for all hex modules
#
# Runs installation checks (via doctor.sh) + all 6 module checks:
#   Memory → hex-events → BOI → startup → landings → workspace
#
# Usage:
#   hex-doctor              # Check all modules, report results
#   hex-doctor --fix        # Auto-fix issues where possible
#   hex-doctor --smoke      # Also run smoke tests (slower, proves end-to-end)
#   hex-doctor --quiet      # Only show errors and warnings
#
# Exit codes:
#   0 = all pass
#   1 = errors found
#   2 = warnings only (no errors)

set -uo pipefail

# ─── Resolve AGENT_DIR ────────────────────────────────────────────────────────
if [ -z "${HEX_DIR:-}" ]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  candidate="$SCRIPT_DIR"
  while [ "$candidate" != "/" ]; do
    if [ -f "$candidate/CLAUDE.md" ]; then
      HEX_DIR="$candidate"
      break
    fi
    candidate="$(dirname "$candidate")"
  done
  HEX_DIR="${HEX_DIR:-$HOME/hex}"
fi

SCRIPTS_DIR="$HEX_DIR/.hex/scripts"
HEX_CHECKS_DIR="$HEX_DIR/.hex/scripts/doctor-checks"

# ─── Flags ────────────────────────────────────────────────────────────────────
FIX=false
SMOKE=false
QUIET=false

for arg in "$@"; do
  case "$arg" in
    --fix)   FIX=true ;;
    --smoke) SMOKE=true ;;
    --quiet) QUIET=true ;;
    --help|-h)
      echo "Usage: hex-doctor [--fix] [--smoke] [--quiet]"
      echo ""
      echo "  --fix    Auto-fix safe issues (restarts daemons, chmod, rebuilds indexes)"
      echo "  --smoke  Run smoke tests proving end-to-end functionality (slower)"
      echo "  --quiet  Only show errors and warnings (suppress PASS lines)"
      exit 0
      ;;
    *) echo "Unknown option: $arg" >&2; exit 1 ;;
  esac
done

# ─── Colors ───────────────────────────────────────────────────────────────────
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ─── State ────────────────────────────────────────────────────────────────────
PASS_COUNT=0
WARN_COUNT=0
ERROR_COUNT=0
FIXED_COUNT=0
HAS_ERRORS=false
HAS_WARNINGS=false

CHECKS_FILE=$(mktemp /tmp/hex-doctor-checks.XXXXXX)
trap 'rm -f "$CHECKS_FILE"' EXIT

# ─── Output helpers ───────────────────────────────────────────────────────────
_pass() {
  PASS_COUNT=$((PASS_COUNT + 1))
  if ! $QUIET; then
    echo -e "  [${GREEN}PASS${RESET}] $1"
  fi
}

_warn() {
  WARN_COUNT=$((WARN_COUNT + 1))
  HAS_WARNINGS=true
  echo -e "  [${YELLOW}WARN${RESET}] $1"
}

_error() {
  ERROR_COUNT=$((ERROR_COUNT + 1))
  HAS_ERRORS=true
  echo -e "  [${RED}ERROR${RESET}] $1"
}

_fixed() {
  FIXED_COUNT=$((FIXED_COUNT + 1))
  echo -e "  [${GREEN}FIXED${RESET}] $1"
}

_info() {
  if ! $QUIET; then
    echo -e "  ${DIM}→${RESET} $1"
  fi
}

_rec() {
  printf '%s\t%s\t%s\t%s\n' "$1" "$2" "$3" "$4" >> "$CHECKS_FILE"
}

# ─── Header ───────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}Hex Doctor — Full System Health Check${RESET}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "${DIM}HEX_DIR=$HEX_DIR${RESET}"
if $FIX;   then echo -e "${DIM}Mode: --fix enabled (auto-remediation on)${RESET}"; fi
if $SMOKE; then echo -e "${DIM}Mode: --smoke enabled (end-to-end tests on)${RESET}"; fi

# ─── Part 1: Installation checks (doctor.sh) ─────────────────────────────────
DOCTOR_SH="$SCRIPTS_DIR/doctor.sh"
INSTALL_ERRORS=0
INSTALL_WARNINGS=0
INSTALL_PASS=0
INSTALL_FIXED=0

if [ -f "$DOCTOR_SH" ]; then
  echo ""
  echo -e "${BOLD}Installation Checks${RESET}"
  echo "  ─────────────────────────────────────────"

  # Run doctor.sh and capture output (avoid empty array with -u)
  if $FIX && $QUIET; then
    doctor_output=$(bash "$DOCTOR_SH" --fix --quiet 2>&1) || true
  elif $FIX; then
    doctor_output=$(bash "$DOCTOR_SH" --fix 2>&1) || true
  elif $QUIET; then
    doctor_output=$(bash "$DOCTOR_SH" --quiet 2>&1) || true
  else
    doctor_output=$(bash "$DOCTOR_SH" 2>&1) || true
  fi

  # Print doctor.sh output (skip the header lines it already prints, show check results)
  # Filter: remove the doctor.sh header (first 4 lines with title/separator/AGENT_DIR/blank)
  echo "$doctor_output" | tail -n +5 | while IFS= read -r line; do
    echo "$line"
  done

  # Parse summary from doctor.sh output: "  Summary: N passed, N warnings, N errors, N fixed"
  summary_line=$(echo "$doctor_output" | grep "Summary:" | tail -1) || summary_line=""
  if [ -n "$summary_line" ]; then
    INSTALL_PASS=$(echo "$summary_line"   | grep -oE '[0-9]+ passed'   | grep -oE '[0-9]+' || echo 0)
    INSTALL_WARNINGS=$(echo "$summary_line" | grep -oE '[0-9]+ warnings' | grep -oE '[0-9]+' || echo 0)
    INSTALL_ERRORS=$(echo "$summary_line"   | grep -oE '[0-9]+ errors'   | grep -oE '[0-9]+' || echo 0)
    INSTALL_FIXED=$(echo "$summary_line"    | grep -oE '[0-9]+ fixed'    | grep -oE '[0-9]+' || echo 0)
    # Merge into global counts
    PASS_COUNT=$((PASS_COUNT + ${INSTALL_PASS:-0}))
    WARN_COUNT=$((WARN_COUNT + ${INSTALL_WARNINGS:-0}))
    ERROR_COUNT=$((ERROR_COUNT + ${INSTALL_ERRORS:-0}))
    FIXED_COUNT=$((FIXED_COUNT + ${INSTALL_FIXED:-0}))
    [ "${INSTALL_ERRORS:-0}" -gt 0 ] && HAS_ERRORS=true
    [ "${INSTALL_WARNINGS:-0}" -gt 0 ] && HAS_WARNINGS=true
  fi
else
  _warn "Installation checks skipped: doctor.sh not found at $DOCTOR_SH"
fi

# ─── Part 2: Module checks ────────────────────────────────────────────────────
MODULE_COUNT=0
CHAIN_STOPPED=false

if [ ! -d "$HEX_CHECKS_DIR" ]; then
  echo ""
  _warn "Module checks dir not found: $HEX_CHECKS_DIR"
else

  # ── Memory (critical) ────────────────────────────────────────────────────────
  if [ -f "$HEX_CHECKS_DIR/memory.sh" ]; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}Memory Module${RESET}"
    echo "  ─────────────────────────────────────────"
    _ERRORS_BEFORE=$ERROR_COUNT
    source "$HEX_CHECKS_DIR/memory.sh"
    run_memory_checks
    if [ "$ERROR_COUNT" -gt "$_ERRORS_BEFORE" ]; then
      CHAIN_STOPPED=true
    fi
  fi

  # ── hex-events ───────────────────────────────────────────────────────────────
  if [ -f "$HEX_CHECKS_DIR/hex-events.sh" ] && ! $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}hex-events Module${RESET}"
    echo "  ─────────────────────────────────────────"
    source "$HEX_CHECKS_DIR/hex-events.sh"
    run_hex_events_checks
  elif [ -f "$HEX_CHECKS_DIR/hex-events.sh" ] && $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "  ${DIM}[SKIP] hex-events — blocked by memory errors${RESET}"
  fi

  # ── BOI ──────────────────────────────────────────────────────────────────────
  if [ -f "$HEX_CHECKS_DIR/boi.sh" ] && ! $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}BOI Module${RESET}"
    echo "  ─────────────────────────────────────────"
    source "$HEX_CHECKS_DIR/boi.sh"
    run_boi_checks
  elif [ -f "$HEX_CHECKS_DIR/boi.sh" ] && $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "  ${DIM}[SKIP] BOI — blocked by memory errors${RESET}"
  fi

  # ── Startup ──────────────────────────────────────────────────────────────────
  if [ -f "$HEX_CHECKS_DIR/startup.sh" ] && ! $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}Startup Module${RESET}"
    echo "  ─────────────────────────────────────────"
    source "$HEX_CHECKS_DIR/startup.sh"
    run_startup_checks
  elif [ -f "$HEX_CHECKS_DIR/startup.sh" ] && $CHAIN_STOPPED; then
    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "  ${DIM}[SKIP] Startup — blocked by memory errors${RESET}"
  fi

  # ── Landings + Workspace (always run even if chain stopped) ──────────────────
  if [ -f "$HEX_CHECKS_DIR/landings-workspace.sh" ]; then
    source "$HEX_CHECKS_DIR/landings-workspace.sh"

    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}Landings Module${RESET}"
    echo "  ─────────────────────────────────────────"
    check_61
    check_62

    MODULE_COUNT=$((MODULE_COUNT + 1))
    echo ""
    echo -e "${BOLD}Workspace Module${RESET}"
    echo "  ─────────────────────────────────────────"
    check_63
    check_64
    check_65
  fi

  # ── hex events status absorption (check_66) ──────────────────────────────────
  # Runs `hex events status` and fails for every policy that failed to parse.
  # One check absorbs all validation hex-events surfaces — future hex-events
  # improvements are inherited automatically.
  check_66() {
    local hex_bin="$HEX_DIR/.hex/bin/hex"
    if [ ! -x "$hex_bin" ]; then
      _warn "hex-events.events-status: hex binary not found ($hex_bin) — skipping"
      _rec 66 "hex-events.events-status" "warn" "hex binary not found"
      return
    fi

    local _timeout_bin
    _timeout_bin=$(command -v gtimeout || command -v timeout || true) 2>/dev/null

    local combined exit_code
    exit_code=0
    if [ -n "$_timeout_bin" ]; then
      combined=$(HEX_DIR="$HEX_DIR" "$_timeout_bin" 10 "$hex_bin" events status 2>&1) || exit_code=$?
    else
      combined=$(HEX_DIR="$HEX_DIR" "$hex_bin" events status 2>&1) || exit_code=$?
    fi

    if [ "$exit_code" -eq 124 ]; then
      _error "hex-events.events-status: timed out after 10s (daemon unresponsive?)"
      _rec 66 "hex-events.events-status" "error" "hex events status timed out"
      return
    fi

    local failures
    failures=$(printf '%s\n' "$combined" | grep '^events: failed to parse ') || true

    if [ -n "$failures" ]; then
      local count
      count=$(printf '%s\n' "$failures" | wc -l | tr -d ' ')
      if [ "$count" -eq 1 ]; then
        _error "hex-events.events-status: 1 policy failed to parse:"
      else
        _error "hex-events.events-status: ${count} policies failed to parse:"
      fi
      while IFS= read -r line; do
        local path err_msg
        path=$(printf '%s' "$line" | sed 's/^events: failed to parse "//;s/": .*//')
        err_msg=$(printf '%s' "$line" | sed 's/^events: failed to parse "[^"]*": //')
        _info "  - $path: $err_msg"
      done <<< "$failures"
      _rec 66 "hex-events.events-status" "error" "${count} parse failure(s)"
      return
    fi

    if [ "$exit_code" -ne 0 ]; then
      local first_line
      first_line=$(printf '%s\n' "$combined" | head -1)
      _error "hex-events.events-status: hex events status exited $exit_code"
      _info "  $first_line"
      _rec 66 "hex-events.events-status" "error" "exit code $exit_code"
      return
    fi

    local policy_count
    policy_count=$(printf '%s\n' "$combined" | grep 'policies loaded:' | grep -oE '[0-9]+' | head -1) || policy_count="?"
    _pass "hex-events.events-status: ${policy_count} policies loaded, 0 parse errors"
    _rec 66 "hex-events.events-status" "pass" "${policy_count} policies loaded"
  }

  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}hex events status${RESET}"
  echo "  ─────────────────────────────────────────"
  check_66

  # ── Version sync (check_67) ──────────────────────────────────────────────────
  # Verifies compiled binary version == Cargo.toml version.
  # WARN (not FAIL) when git tag lags Cargo.toml — that's expected between bumps.
  check_67() {
    local harness_toml="$HEX_DIR/.hex/harness/Cargo.toml"
    local hex_bin="$HEX_DIR/.hex/bin/hex"
    local foundation_repo="$HOME/github.com/mrap/hex-foundation"

    if [ ! -f "$harness_toml" ]; then
      _warn "version-sync: harness Cargo.toml not found ($harness_toml) — skipping"
      _rec 67 "version-sync" "warn" "Cargo.toml not found"
      return
    fi

    local CARGO_VER
    CARGO_VER=$(grep -E '^version' "$harness_toml" | head -1 | cut -d'"' -f2)

    if [ -z "$CARGO_VER" ]; then
      _error "version-sync: could not read version from $harness_toml"
      _rec 67 "version-sync" "error" "could not parse Cargo.toml version"
      return
    fi

    if [ ! -x "$hex_bin" ]; then
      _error "version-sync: hex binary not found or not executable ($hex_bin)"
      _rec 67 "version-sync" "error" "hex binary missing"
      return
    fi

    local hex_version
    hex_version=$("$hex_bin" --version 2>&1 | awk '{print $2}')

    if [ "$CARGO_VER" != "$hex_version" ]; then
      _error "version-sync: Cargo.toml=$CARGO_VER but binary reports $hex_version — rebuild needed"
      _info  "  Run: cd $HEX_DIR/.hex/harness && cargo build --release && cp target/release/hex $hex_bin"
      _rec 67 "version-sync" "error" "Cargo.toml=$CARGO_VER binary=$hex_version"
      return
    fi

    _pass "version-sync: Cargo.toml == binary == $CARGO_VER"
    _rec 67 "version-sync" "pass" "$CARGO_VER"

    local TAG_VER
    TAG_VER=$(git -C "$foundation_repo" describe --tags --abbrev=0 2>/dev/null | sed 's/^v//') || TAG_VER=""

    if [ -n "$TAG_VER" ] && [ "$TAG_VER" != "$CARGO_VER" ]; then
      _warn "version-sync: latest git tag v$TAG_VER != Cargo.toml $CARGO_VER (expected between bumps)"
      _rec 67 "version-sync.tag" "warn" "tag=$TAG_VER cargo=$CARGO_VER"
    elif [ -n "$TAG_VER" ]; then
      if ! $QUIET; then
        echo -e "  [${GREEN}PASS${RESET}] version-sync: git tag v$TAG_VER matches Cargo.toml"
      fi
    fi
  }

  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Version Sync${RESET}"
  echo "  ─────────────────────────────────────────"
  check_67

  # ── hex binary version-sync (check_68) ──────────────────────────────────────
  # Verifies the `hex` binary on PATH matches the Cargo.toml version.
  # Detects a stale PATH binary after a foundation repo upgrade.
  # HEX_FOUNDATION_DIR can be overridden (default: ~/github.com/mrap/hex-foundation).
  check_68() {
    local foundation_dir="${HEX_FOUNDATION_DIR:-$HOME/github.com/mrap/hex-foundation}"
    local foundation_toml="$foundation_dir/system/harness/Cargo.toml"
    local installed_toml="$HEX_DIR/.hex/harness/Cargo.toml"
    local toml_path

    if [ -f "$foundation_toml" ]; then
      toml_path="$foundation_toml"
    elif [ -f "$installed_toml" ]; then
      toml_path="$installed_toml"
    else
      _warn "hex-binary version-sync: Cargo.toml not found — skipping"
      _rec 68 "hex-binary version-sync" "warn" "Cargo.toml not found"
      return
    fi

    local CARGO_VER
    CARGO_VER=$(grep -E '^version' "$toml_path" | head -1 | cut -d'"' -f2)

    if [ -z "$CARGO_VER" ]; then
      _error "hex-binary version-sync: could not read version from $toml_path"
      _rec 68 "hex-binary version-sync" "error" "could not parse Cargo.toml version"
      return
    fi

    local hex_path
    hex_path=$(command -v hex 2>/dev/null) || true

    if [ -z "$hex_path" ]; then
      _error "hex-binary version-sync: hex not found on PATH"
      _rec 68 "hex-binary version-sync" "error" "hex not on PATH"
      return
    fi

    local BIN_VER
    BIN_VER=$(hex --version 2>&1 | awk '{print $2}')

    if [ "$BIN_VER" = "$CARGO_VER" ]; then
      _pass "hex-binary version-sync: hex binary == Cargo.toml == $CARGO_VER"
      _rec 68 "hex-binary version-sync" "pass" "$CARGO_VER"
    else
      _error "hex-binary version-sync: binary=$BIN_VER but Cargo.toml=$CARGO_VER — rebuild needed"
      _info  "  Run: cd ~/github.com/mrap/hex-foundation && make install"
      _rec 68 "hex-binary version-sync" "error" "binary=$BIN_VER cargo=$CARGO_VER"
    fi
  }

  MODULE_COUNT=$((MODULE_COUNT + 1))
  echo ""
  echo -e "${BOLD}Hex Binary Version Sync${RESET}"
  echo "  ─────────────────────────────────────────"
  check_68

fi

# ─── Summary ──────────────────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if $CHAIN_STOPPED; then
  echo -e "  ${YELLOW}⚠ Memory module had errors — dependent modules were skipped${RESET}"
fi

echo -e "  ${BOLD}Summary:${RESET} ${MODULE_COUNT} modules checked"
echo -e "           ${PASS_COUNT} checks passed, ${WARN_COUNT} warnings, ${ERROR_COUNT} errors, ${FIXED_COUNT} auto-fixed"

if $HAS_ERRORS; then
  echo ""
  echo -e "  ${RED}✗ System not healthy — run with --fix to attempt auto-remediation${RESET}"
elif $HAS_WARNINGS; then
  echo ""
  echo -e "  ${YELLOW}⚠ Some warnings detected — run with --fix to resolve${RESET}"
else
  echo ""
  echo -e "  ${GREEN}✓ All systems healthy${RESET}"
fi
echo ""

# ─── Exit code ────────────────────────────────────────────────────────────────
if $HAS_ERRORS; then
  exit 1
elif $HAS_WARNINGS; then
  exit 2
fi
exit 0
